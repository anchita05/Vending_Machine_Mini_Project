module vending_machine(
    input clk,
    input rst,
    input coin5,
    input coin10,
    output reg dispense
);
    // State definitions
    parameter [1:0] s0 = 2'b00, 
                    s1 = 2'b01,
                    s2 = 2'b10;

    reg [1:0] state, next_state;
    
    //Reset logic
    always @(posedge clk or posedge rst) begin
        if(rst)
            state <= s0;
        else
            state <= next_state;
    end
    
    //Next State Logic
    always @(*) begin
        case(state)
            s0 : begin
                if(coin10)
                    next_state = s2;
                else if(coin5)
                    next_state = s1;
                else
                    next_state = s0; 
            end   
            
            s1 : begin
                if(coin5 || coin10) 
                    next_state = s2;
                else
                    next_state = s1;
            end
            
            s2 : begin
                if(coin5 || coin10)
                    next_state = s2; 
                else
                    next_state = s0;
            end
            
            default : next_state = s0;
        endcase
    end
    
    //Output Logic
    always @(*) begin
        dispense = (state == s2);
    end  

endmodule
